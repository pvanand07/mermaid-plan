{
  "name": "mermaid-plan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "pnpm run --parallel \"/^(dev|dev:server)$/\"",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "start:server": "node dist-server/server/index.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File deploy/ssh-deploy.ps1",
    "deploy:bash": "bash deploy/ssh-deploy.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@openrouter/agent": "^0.7.1",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "eventsource-parser": "^3.1.0",
    "hono": "^4.12.25",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
