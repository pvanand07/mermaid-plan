# Copy to .env before: docker compose up -d --build

# Public app origin (CORS on agent) — hostname or full URL
APP_URL=diagram-studio.elevatics.site

# Public agent API origin (baked into frontend at build time)
DIAGRAM_AGENT_URL=agent-diagram-studio.elevatics.site

# OpenRouter — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional
OPENROUTER_MODEL=openai/gpt-4o-mini
TRUST_PROXY=true
RATE_LIMIT_ENABLED=true

# Host port mappings (omit when behind a reverse proxy on the host)
WEB_PORT=8080
AGENT_PORT=3001
