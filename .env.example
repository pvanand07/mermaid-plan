# OpenRouter — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional overrides
OPENROUTER_MODEL=openai/gpt-4o-mini
PORT=3001
HOST=127.0.0.1

# Production deployment (Docker / reverse proxy)
# APP_URL — browser origin for the SPA; used for agent CORS (https added if omitted)
# APP_URL=diagram-studio.elevatics.site
# DIAGRAM_AGENT_URL — public agent API origin; baked into frontend via VITE_DIAGRAM_AGENT_URL at build
# DIAGRAM_AGENT_URL=agent-diagram-studio.elevatics.site
# VITE_DIAGRAM_AGENT_URL=agent-diagram-studio.elevatics.site

# Comma-separated browser origins allowed to call /api/* (dev defaults if APP_URL unset)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Trust X-Forwarded-For / X-Real-IP when behind a reverse proxy
# TRUST_PROXY=true

# Set to false to disable all rate limits (local debugging)
# RATE_LIMIT_ENABLED=true

# Per-endpoint limits: requests allowed per IP per window
# Windows: PER_MIN, PER_HOUR, PER_DAY, PER_WEEK, PER_MONTH (month = 30-day rolling)

# Health check — GET /api/health
# RATE_LIMIT_HEALTH_PER_MIN=120
# RATE_LIMIT_HEALTH_PER_HOUR=1000
# RATE_LIMIT_HEALTH_PER_DAY=5000
# RATE_LIMIT_HEALTH_PER_WEEK=20000
# RATE_LIMIT_HEALTH_PER_MONTH=30000

# Global agent backstop — all /api/agent/*
# RATE_LIMIT_AGENT_GLOBAL_PER_MIN=25
# RATE_LIMIT_AGENT_GLOBAL_PER_HOUR=180
# RATE_LIMIT_AGENT_GLOBAL_PER_DAY=700
# RATE_LIMIT_AGENT_GLOBAL_PER_WEEK=3000
# RATE_LIMIT_AGENT_GLOBAL_PER_MONTH=4500

# Non-streaming chat — POST /api/agent/chat (unused by UI; strict)
# RATE_LIMIT_CHAT_PER_MIN=3
# RATE_LIMIT_CHAT_PER_HOUR=10
# RATE_LIMIT_CHAT_PER_DAY=30
# RATE_LIMIT_CHAT_PER_WEEK=100
# RATE_LIMIT_CHAT_PER_MONTH=150

# Stream turns — POST /api/agent/chat/stream
# RATE_LIMIT_STREAM_PER_MIN=4
# RATE_LIMIT_STREAM_PER_HOUR=20
# RATE_LIMIT_STREAM_PER_DAY=100
# RATE_LIMIT_STREAM_PER_WEEK=400
# RATE_LIMIT_STREAM_PER_MONTH=600

# Tool continues — POST /api/agent/chat/continue
# RATE_LIMIT_CONTINUE_PER_MIN=10
# RATE_LIMIT_CONTINUE_PER_HOUR=75
# RATE_LIMIT_CONTINUE_PER_DAY=300
# RATE_LIMIT_CONTINUE_PER_WEEK=1250
# RATE_LIMIT_CONTINUE_PER_MONTH=1875
